# Local generated backups / image seeds (keep out of git)
assets/sounds/*.wav.backup_*
assets/images/themes/**/**/*_prev_*.png
assets/images/themes/**/*seed*.png

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated Dart source files should be versioned when relied on at runtime.

# Hive
*.hive

# Artifacts (generated UI dumps)
artifacts/ui*.xml
artifacts/screenshots/**/ui*.xml

# Artifacts (ComfyUI generations)
artifacts/comfyui/
artifacts/mascot_frames/

# Artifacts (procedural mascot capture / experiments)
artifacts/procedural_idle_poc/

# Local generated images (keep out of git)
assets/images/generated/

# Local preview images (keep out of git)
assets/images/themes/**/**/*_preview*.png

# Signing keys (SECRET - never commit)
android/upload-keystore.jks
android/key.properties
