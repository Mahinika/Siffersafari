{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "testPath",
      "type": "promptString",
      "description": "Testfil eller mapp att köra (t.ex. test/question_generator_test.dart eller test/)",
      "default": "test/"
    },
    {
      "id": "characterName",
      "type": "promptString",
      "description": "Karaktarens visningsnamn (t.ex. Mira)",
      "default": "Mira"
    },
    {
      "id": "characterBrief",
      "type": "promptString",
      "description": "Kort beskrivning av stil, tema och farger",
      "default": "space explorer with teal jacket and gold backpack"
    },
    {
      "id": "characterSlug",
      "type": "promptString",
      "description": "Existerande karaktarslug att regenerera (t.ex. loke)",
      "default": "loke"
    }
  ],
  "tasks": [
    {
      "label": "Flutter: Run (Pixel_6 only)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/flutter_pixel6.ps1",
        "-Action",
        "run",
        "-ClearLogcatBeforeRun",
        "-DumpLogcatOnLostConnection",
        "-DumpLogcatAfterRun"
      ],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Flutter: Install (Pixel_6 only)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/flutter_pixel6.ps1",
        "-Action",
        "install"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Flutter: Sync (Pixel_6 only)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/flutter_pixel6.ps1",
        "-Action",
        "sync"
      ],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "QA: Analyze",
      "type": "shell",
      "command": "flutter",
      "args": ["analyze"],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "QA: Test (valfri path)",
      "type": "shell",
      "command": "flutter",
      "args": ["test", "${input:testPath}"],
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "QA: Test (alla)",
      "type": "shell",
      "command": "flutter",
      "args": ["test"],
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "QA: Analyze + Test (valfri path)",
      "dependsOrder": "sequence",
      "dependsOn": ["QA: Analyze", "QA: Test (valfri path)"],
      "problemMatcher": []
    },
    {
      "label": "QA: Analyze + Full Test (stora ändringar)",
      "dependsOrder": "sequence",
      "dependsOn": ["QA: Analyze", "QA: Test (alla)"],
      "problemMatcher": []
    },
    {
      "label": "Pixel_6: Sync + QA (valfri testpath)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Flutter: Sync (Pixel_6 only)",
        "QA: Analyze + Test (valfri path)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Assets: Create Character From Brief",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/create_character.py",
        "--name",
        "${input:characterName}",
        "--brief",
        "${input:characterBrief}"
      ],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Assets: Refresh Existing Character",
      "type": "shell",
      "command": "python",
      "args": [
        "tools/refresh_character.py",
        "--slug",
        "${input:characterSlug}"
      ],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Assets: Generate Mascot SVG Parts",
      "type": "shell",
      "command": "dart",
      "args": ["run", "scripts/generate_mascot_svg_parts.dart"],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Assets: Generate Lottie Effects",
      "type": "shell",
      "command": "dart",
      "args": ["run", "scripts/generate_lottie_effects.dart"],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Assets: Generate Rive Blueprint",
      "type": "shell",
      "command": "dart",
      "args": ["run", "scripts/generate_rive_blueprint.dart"],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Assets: Generate Mascot Composite SVG",
      "type": "shell",
      "command": "dart",
      "args": ["run", "scripts/generate_mascot_composite.dart"],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },
    {
      "label": "Assets: Generate All (SVG + Lottie + Rive Blueprint)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Assets: Generate Mascot SVG Parts",
        "Assets: Generate Lottie Effects",
        "Assets: Generate Rive Blueprint",
        "Assets: Generate Mascot Composite SVG"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "QA: Difficulty Mix Audit",
      "type": "shell",
      "command": "flutter",
      "args": ["test", "test/unit/audits/difficulty_mix_audit_test.dart"],
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "QA: Integration Smoke (core)",
      "type": "shell",
      "command": "flutter",
      "args": [
        "test",
        "integration_test/app_smoke_test.dart",
        "--dart-define=FULL_SMOKE=false"
      ],
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "QA: Integration Smoke (full)",
      "type": "shell",
      "command": "flutter",
      "args": [
        "test",
        "integration_test/app_smoke_test.dart",
        "--dart-define=FULL_SMOKE=true"
      ],
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
